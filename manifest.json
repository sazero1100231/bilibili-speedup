{
  "manifest_version": 3,
  "name": "Bilibili 海外播放加速與追蹤淨化",
  "short_name": "Bili 海外加速",
  "version": "1.1.17",
  "description": "以本地 CDN 節點評估、playurl 改寫與追蹤淨化改善 Bilibili 海外播放體驗。",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "https://*.bilivideo.com/*",
    "https://upos-hz-mirrorakam.akamaized.net/*",
    "https://*.bilivideo.cn/*",
    "*://b23.tv/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bili 海外加速",
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "options_page": "src/ui/options.html",
  "minimum_chrome_version": "120"
}
